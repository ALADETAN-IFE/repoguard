APP_ID=your_app_id_here
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# If using a .pem file for the private key, comment out the above line and use this instead:
# PRIVATE_KEY_PATH=./path-to-your-private-key.pem
WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_CLIENT_ID=your_oauth_client_id
GITHUB_CLIENT_SECRET=your_oauth_client_secret
MONGODB_URI=mongodb+srv://your-user:your-password@cluster.mongodb.net/repoguard

PORT=3000
LOG_LEVEL=info

# Optional integrations
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=

# Local dev only
WEBHOOK_PROXY_URL=https://smee.io/your-channel-id
