{
  "name": "repoguard",
  "version": "1.0.0",
  "description": "GitHub App that detects and blocks malicious commits, unauthorized pushes, and workflow-based re-infection.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --max-old-space-size=400 dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --coverage",
    "lint": "eslint src/ --ext .ts",
    "lintfix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "check-format": "prettier --check \"src/**/*.{ts,json}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --max-warnings=0",
      "tsc --noEmit"
    ]
  },
  "dependencies": {
    "@octokit/app": "^14.0.0",
    "@octokit/rest": "^20.0.0",
    "@octokit/types": "^13.0.0",
    "@octokit/webhooks": "^10.9.2",
    "@octokit/webhooks-types": "^7.0.0",
    "adm-zip": "^0.5.17",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "mongoose": "^8.24.0",
    "prettier": "^3.8.4",
    "rate-limit-redis": "^5.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "lint-staged": "^17.0.8",
    "ts-jest": "^29.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
